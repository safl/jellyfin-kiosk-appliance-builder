#cloud-config

hostname: jellyfin-tv
timezone: Europe/Copenhagen

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

bootcmd:
  - sed -i '/^Components:/s/$/ contrib non-free/' /etc/apt/sources.list.d/debian.sources

package_update: true
package_upgrade: true

chpasswd:
  expire: false
  users:
  - {name: root, password: root, type: text}

ssh_pwauth: true

users:
  - name: jellyfin
    gecos: JKAB
    groups: [sudo, audio, video, input, plugdev, render]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    plain_text_passwd: jellyfin

packages:
  - xfce4
  - lightdm
  - lightdm-gtk-greeter
  - dbus-user-session
  - xdotool
  - cec-utils
  - unclutter
  - x11-xserver-utils
  - network-manager
  - network-manager-gnome
  - firmware-linux-nonfree
  - intel-media-va-driver-non-free
  - i965-va-driver-shaders
  - mesa-va-drivers
  - udisks2
  - ntfs-3g
  - exfatprogs
  - curl
  - python3
  - yad
  - plymouth-themes
  - ca-certificates
  - openssh-server

runcmd:
  - mkdir -p /home/jellyfin/.config/autostart
  - mkdir -p /home/jellyfin/bin
  - chown -R jellyfin:jellyfin /home/jellyfin

  # Jellyfin server (jellyfin-server, jellyfin-web, jellyfin-ffmpeg)
  - mkdir -p /etc/apt/keyrings
  - curl -fsSL https://repo.jellyfin.org/jellyfin_team.gpg.key -o /etc/apt/keyrings/jellyfin.gpg
  - echo "deb [signed-by=/etc/apt/keyrings/jellyfin.gpg arch=amd64] https://repo.jellyfin.org/debian trixie main" > /etc/apt/sources.list.d/jellyfin.list
  - apt-get update
  - apt-get install -y jellyfin
  - systemctl enable jellyfin
  - usermod -aG render jellyfin || true
  - usermod -aG video jellyfin || true

  # Jellyfin Media Player (client) - native deb, latest release
  - curl -fsSL "https://api.github.com/repos/jellyfin/jellyfin-media-player/releases/latest" | python3 -c "import sys,json; assets=json.load(sys.stdin)['assets']; url=next(a['browser_download_url'] for a in assets if 'trixie' in a['name']); print(url)" | xargs curl -fsSL -o /tmp/jellyfin-media-player.deb
  - apt-get install -y /tmp/jellyfin-media-player.deb

  - systemctl set-default graphical.target
  - systemctl enable lightdm
  - systemctl restart systemd-logind
  - systemctl restart ssh

  # Switch to NetworkManager (cloud image uses ifupdown)
  - systemctl disable networking
  - systemctl enable NetworkManager

  # Disable all automatic updates
  - systemctl disable apt-daily.timer apt-daily-upgrade.timer || true
  - systemctl mask apt-daily.service apt-daily-upgrade.service || true
  - apt-get remove -y unattended-upgrades || true

  - udevadm control --reload-rules
  - systemctl enable jkab-mount-all.service
  - systemctl enable serial-getty@ttyS0.service

  # Smooth boot: Plymouth splash + quiet kernel
  - plymouth-set-default-theme spinner
  - update-initramfs -u
  - sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="[^"]*"/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"/' /etc/default/grub
  - update-grub || true

  # Prevent boot failure when EFI partition is absent (BIOS boot)
  - sed -i 's|.*boot/efi.*|# &|' /etc/fstab

  # Sample media for testing playback
  - mkdir -p /media/sample
  - curl -fsSL -o /media/sample/Big_Buck_Bunny_Trailer.mp4 "https://download.blender.org/peach/trailer/trailer_480p.mov"

  # Clean up for smaller image
  - apt-get clean
  - rm -rf /var/lib/apt/lists/*
  - rm -rf /tmp/*
  - fstrim -av || true

  - touch /etc/cloud/cloud-init.disabled

final_message: "Jellyfin kiosk appliance provisioned after $UPTIME seconds"
power_state:
  mode: poweroff
  message: "Provisioning complete, shutting down"
  timeout: 120
  condition: true


write_files:
  - path: /etc/lightdm/lightdm.conf.d/90-autologin.conf
    owner: root:root
    permissions: "0644"
    content: |
      [Seat:*]
      autologin-user=jellyfin
      autologin-user-timeout=0
      user-session=xfce
      greeter-session=lightdm-gtk-greeter
      allow-guest=false

  - path: /etc/ssh/sshd_config.d/00-cijoe.conf
    owner: root:root
    permissions: "0644"
    content: |
      PermitRootLogin yes
      PermitEmptyPasswords yes
      PasswordAuthentication yes

  - path: /etc/systemd/logind.conf.d/90-power-button.conf
    owner: root:root
    permissions: "0644"
    content: |
      [Login]
      HandlePowerKey=poweroff
      HandlePowerKeyLongPress=poweroff
      HandleLidSwitch=ignore

  - path: /etc/systemd/system/jkab-mount-all.service
    owner: root:root
    permissions: "0644"
    content: |
      [Unit]
      Description=Mount all block devices with filesystems
      After=local-fs.target
      
      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/jkab-mount-all.sh
      
      [Install]
      WantedBy=multi-user.target

  - path: /etc/udev/rules.d/90-automount-media.rules
    owner: root:root
    permissions: "0644"
    content: |
      ACTION=="add", SUBSYSTEM=="block", ENV{ID_FS_USAGE}=="filesystem", RUN+="/usr/local/bin/jkab-automount.sh %k"
      ACTION=="remove", SUBSYSTEM=="block", ENV{ID_FS_USAGE}=="filesystem", RUN+="/usr/local/bin/jkab-umount.sh %k"

  - path: /etc/udev/rules.d/99-pulse-eight-cec.rules
    owner: root:root
    permissions: "0644"
    content: |
      SUBSYSTEM=="tty", ATTRS{idVendor}=="2548", ATTRS{idProduct}=="1001", MODE="0666", GROUP="plugdev", SYMLINK+="cec%n"
      SUBSYSTEM=="tty", ATTRS{idVendor}=="2548", ATTRS{idProduct}=="1002", MODE="0666", GROUP="plugdev", SYMLINK+="cec%n"

  - path: /home/jellyfin/.config/autostart/cec-bridge.desktop
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      [Desktop Entry]
      Type=Application
      Name=CEC Bridge
      Exec=/home/jellyfin/bin/cec-jellyfin.sh
      X-GNOME-Autostart-enabled=true
      Terminal=false

  - path: /home/jellyfin/.config/autostart/display-tweaks.desktop
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      [Desktop Entry]
      Type=Application
      Name=Display Tweaks
      Exec=/home/jellyfin/bin/display-tweaks.sh
      X-GNOME-Autostart-enabled=true
      Terminal=false

  - path: /home/jellyfin/.config/autostart/jellyfin.desktop
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      [Desktop Entry]
      Type=Application
      Name=Jellyfin Media Player
      Exec=/home/jellyfin/bin/jellyfin-start.sh
      X-GNOME-Autostart-enabled=true
      Terminal=false

  - path: /home/jellyfin/.config/autostart/unclutter.desktop
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      [Desktop Entry]
      Type=Application
      Name=Unclutter
      Exec=unclutter --timeout 1 --jitter 4
      X-GNOME-Autostart-enabled=true
      Terminal=false

  - path: /home/jellyfin/.config/xfce4/xfconf/xfce-perchannel-xml/xfce4-power-manager.xml
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      <?xml version="1.0" encoding="UTF-8"?>
      <channel name="xfce4-power-manager" version="1.0">
        <property name="xfce4-power-manager" type="empty">
          <property name="power-button-action" type="uint" value="4"/>
          <property name="dpms-enabled" type="bool" value="false"/>
        </property>
      </channel>

  - path: /home/jellyfin/.xsessionrc
    owner: jellyfin:jellyfin
    permissions: "0644"
    defer: true
    content: |
      export GTK_USE_PORTAL=1

  - path: /home/jellyfin/bin/cec-jellyfin.sh
    owner: jellyfin:jellyfin
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      cec-client -d 1 2>/tmp/cec-bridge.log | while read -r line; do
        case "$line" in
          *"key: up"*) xdotool key Up ;;
          *"key: down"*) xdotool key Down ;;
          *"key: left"*) xdotool key Left ;;
          *"key: right"*) xdotool key Right ;;
          *"key: select"*) xdotool key Return ;;
          *"key: back"*) xdotool key Escape ;;
          *"key: exit"*) xdotool key Escape ;;
          *"key: play"*) xdotool key space ;;
          *"key: pause"*) xdotool key space ;;
          *"key: stop"*) xdotool key s ;;
        esac
      done

  - path: /home/jellyfin/bin/display-tweaks.sh
    owner: jellyfin:jellyfin
    permissions: "0755"
    defer: true
    content: |
      #!/bin/sh
      # Disable screensaver and power management
      xset s off
      xset -dpms
      xset s noblank

  - path: /home/jellyfin/bin/jellyfin-start.sh
    owner: jellyfin:jellyfin
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      # Wait for the local Jellyfin server, complete initial setup, then launch client
      SERVER="http://localhost:8096"
      AUTH_HEADER='MediaBrowser Client="JKAB", Device="JKAB", DeviceId="jkab", Version="1.0"'
      
      LIBRARY_OPTS='{"SaveLocalMetadata":true,"SaveSubtitlesWithMedia":true,"SaveLyricsWithMedia":true,"SaveTrickplayWithMedia":true}'
      
      # Show splash screen while waiting for the server
      yad --fullscreen --no-buttons --no-escape --undecorated \
          --text-align=center --justify=center \
          --text="\n\n\n\n\nStarting Jellyfin..." \
          --text-info --fore="#ffffff" --back="#101010" \
          --fontname="Sans 24" &
      SPLASH_PID=$!
      
      # Wait for server to be ready
      for i in $(seq 1 30); do
          curl -sf "$SERVER/System/Ping" >/dev/null 2>&1 && break
          sleep 2
      done
      
      # Complete setup wizard if not already done
      if curl -sf "$SERVER/Startup/Configuration" >/dev/null 2>&1; then
          curl -sf -X POST "$SERVER/Startup/Configuration" \
              -H "Content-Type: application/json" \
              -d '{"UICulture":"en-US","MetadataCountryCode":"US","PreferredMetadataLanguage":"en"}' >/dev/null 2>&1
      
          curl -sf -X POST "$SERVER/Startup/User" \
              -H "Content-Type: application/json" \
              -d '{"Name":"Jellyfin","Password":"jellyfin"}' >/dev/null 2>&1
      
          curl -sf -X POST "$SERVER/Startup/RemoteAccess" \
              -H "Content-Type: application/json" \
              -d '{"EnableRemoteAccess":true,"EnableAutomaticPortMapping":false}' >/dev/null 2>&1
      
          curl -sf -X POST "$SERVER/Startup/Complete" >/dev/null 2>&1
      
          # Save metadata alongside media files (survives image reflash)
          curl -sf -X POST "$SERVER/System/Configuration" \
              -H "Content-Type: application/json" \
              -d '{"ImageSavingConvention":"Compatible"}' >/dev/null 2>&1
      
          # Authenticate to get a token for library setup
          TOKEN=$(curl -sf -X POST "$SERVER/Users/AuthenticateByName" \
              -H "Content-Type: application/json" \
              -H "Authorization: $AUTH_HEADER" \
              -d '{"Username":"Jellyfin","Pw":"jellyfin"}' | \
              python3 -c "import sys,json; print(json.load(sys.stdin)['AccessToken'])" 2>/dev/null)
      
          if [ -n "$TOKEN" ]; then
              AUTH="$AUTH_HEADER, Token=\"$TOKEN\""
      
              # Add default media libraries — both scan /media/ so USB/SD content appears automatically
              curl -sf -X POST "$SERVER/Library/VirtualFolders?name=Movies&collectionType=movies&paths=%2Fmedia&refreshLibrary=false" \
                  -H "Authorization: $AUTH" \
                  -H "Content-Type: application/json" \
                  -d "$LIBRARY_OPTS" >/dev/null 2>&1
      
              curl -sf -X POST "$SERVER/Library/VirtualFolders?name=Shows&collectionType=tvshows&paths=%2Fmedia&refreshLibrary=true" \
                  -H "Authorization: $AUTH" \
                  -H "Content-Type: application/json" \
                  -d "$LIBRARY_OPTS" >/dev/null 2>&1
          fi
      fi
      
      # Kill splash
      kill "$SPLASH_PID" 2>/dev/null
      wait "$SPLASH_PID" 2>/dev/null
      
      # Auto-detect scale factor based on resolution
      SCALE=1
      RES=$(xrandr 2>/dev/null | grep '\*' | head -1 | awk '{print $1}' | cut -d'x' -f1)
      if [ "${RES:-0}" -ge 3840 ]; then
          SCALE=2
      fi
      
      exec jellyfinmediaplayer --fullscreen --scale-factor="$SCALE"

  - path: /usr/local/bin/jkab-automount.sh
    owner: root:root
    permissions: "0755"
    content: |
      #!/bin/bash
      # Auto-mount removable media
      DEVICE="/dev/$1"
      LABEL=$(blkid -s LABEL -o value "$DEVICE" 2>/dev/null || echo "$1")
      MOUNT="/media/${LABEL}"
      
      mkdir -p "$MOUNT"
      mount "$DEVICE" "$MOUNT"

  - path: /usr/local/bin/jkab-install-extras.sh
    owner: root:root
    permissions: "0644"
    content: |
      #!/usr/bin/env bash
      # Install optional diagnostic and debugging packages
      set -e
      
      sudo apt-get update
      sudo apt-get install -y \
        intel-gpu-tools \
        mesa-utils \
        psmisc \
        va-driver-all \
        vainfo \
        xfce4-goodies
      
      echo "Done — extras installed."

  - path: /usr/local/bin/jkab-mount-all.sh
    owner: root:root
    permissions: "0755"
    content: |
      #!/bin/bash
      # Mount all unmounted block devices with filesystems
      for DEV in $(lsblk -rno NAME,FSTYPE | awk '$2 != "" {print $1}'); do
          DEVICE="/dev/$DEV"
          # Skip if already mounted or if it's the root/boot device
          findmnt -n "$DEVICE" >/dev/null 2>&1 && continue
          LABEL=$(blkid -s LABEL -o value "$DEVICE" 2>/dev/null || echo "$DEV")
          MOUNT="/media/${LABEL}"
          mkdir -p "$MOUNT"
          mount "$DEVICE" "$MOUNT" 2>/dev/null
      done

  - path: /usr/local/bin/jkab-umount.sh
    owner: root:root
    permissions: "0755"
    content: |
      #!/bin/bash
      # Unmount removable media
      DEVICE="/dev/$1"
      MOUNT=$(findmnt -n -o TARGET "$DEVICE" 2>/dev/null)
      
      if [ -n "$MOUNT" ]; then
          umount "$MOUNT"
          rmdir "$MOUNT" 2>/dev/null
      fi

