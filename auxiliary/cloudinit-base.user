#cloud-config

hostname: jellyfin-tv
timezone: __JKAB_TIMEZONE__

growpart:
  mode: auto
  devices: ["/"]

resize_rootfs: true

bootcmd:
  - sed -i '/^Components:/s/$/ contrib non-free/' /etc/apt/sources.list.d/debian.sources

chpasswd:
  expire: false
  users:
  - {name: root, password: root, type: text}

ssh_pwauth: true

users:
  - name: jellyfin
    gecos: JKAB
    groups: [sudo, audio, video, input, plugdev, render]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    lock_passwd: false
    plain_text_passwd: jellyfin

runcmd:
  - mkdir -p /home/jellyfin/.config/openbox
  - mkdir -p /home/jellyfin/bin
  - chown -R jellyfin:jellyfin /home/jellyfin

  # System packages
  - apt-get update -q
  - DEBIAN_FRONTEND=noninteractive apt-get upgrade -qy -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold"
  - DEBIAN_FRONTEND=noninteractive apt-get install -qy openbox xinit x11-xserver-utils dbus-user-session unclutter cec-utils xdotool network-manager intel-media-va-driver-non-free i965-va-driver-shaders mesa-va-drivers udisks2 ntfs-3g exfatprogs curl python3 plymouth-themes ca-certificates openssh-server

  # Jellyfin server (jellyfin-server, jellyfin-web, jellyfin-ffmpeg)
  - mkdir -p /etc/apt/keyrings
  - curl -fsSL https://repo.jellyfin.org/jellyfin_team.gpg.key -o /etc/apt/keyrings/jellyfin.gpg
  - echo "deb [signed-by=/etc/apt/keyrings/jellyfin.gpg arch=amd64] https://repo.jellyfin.org/debian trixie main" > /etc/apt/sources.list.d/jellyfin.list
  - apt-get update -q
  - apt-get install -qy jellyfin
  - systemctl enable jellyfin
  - usermod -aG render jellyfin || true
  - usermod -aG video jellyfin || true

  # Jellyfin Media Player (client) - native deb, latest release
  - curl -fsSL "https://api.github.com/repos/jellyfin/jellyfin-media-player/releases/latest" | python3 -c "import sys,json; assets=json.load(sys.stdin)['assets']; url=next(a['browser_download_url'] for a in assets if 'trixie' in a['name']); print(url)" | xargs curl -fsSL -o /tmp/jellyfin-media-player.deb
  - apt-get install -qy /tmp/jellyfin-media-player.deb

  - systemctl set-default multi-user.target
  - systemctl restart systemd-logind
  - systemctl restart ssh

  # Switch to NetworkManager (cloud image uses ifupdown)
  - systemctl disable networking
  - systemctl enable NetworkManager

  # Disable all automatic updates
  - systemctl disable apt-daily.timer apt-daily-upgrade.timer || true
  - systemctl mask apt-daily.service apt-daily-upgrade.service || true
  - apt-get remove -qy unattended-upgrades || true

  - udevadm control --reload-rules
  - systemctl enable serial-getty@ttyS0.service

  # Smooth boot: Plymouth splash + quiet kernel (clear cloud image serial console defaults)
  - plymouth-set-default-theme spinner
  - update-initramfs -u
  - sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="[^"]*"/GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"/' /etc/default/grub
  - sed -i 's/GRUB_CMDLINE_LINUX="[^"]*"/GRUB_CMDLINE_LINUX=""/' /etc/default/grub
  - update-grub || true

  # Prevent boot failure when EFI partition is absent (BIOS boot)
  - sed -i 's|.*boot/efi.*|# &|' /etc/fstab

  # Sample media for testing playback (Blender open movies, Creative Commons)
  - mkdir -p /media/Misc
  - curl -fsSL -o "/media/Misc/Sintel (2010).mp4" "https://download.blender.org/durian/trailer/sintel_trailer-720p.mp4"
  - curl -fsSL -o "/media/Misc/Big Buck Bunny (2008).mp4" "https://archive.org/download/BigBuckBunny_328/BigBuckBunny_512kb.mp4"

  # Clean up for smaller image
  - apt-get clean
  - rm -rf /var/lib/apt/lists/*
  - rm -rf /tmp/*
  - fstrim -av || true

  - touch /etc/cloud/cloud-init.disabled

final_message: "Jellyfin kiosk appliance provisioned after $UPTIME seconds"
power_state:
  mode: poweroff
  message: "Provisioning complete, shutting down"
  timeout: 120
  condition: true
